###    global git config  (~/.gitconfig)

[core]
    autocrlf = input
    eol = lf
    editor = nano
    excludesfile = ~/.gitignore  # Switch to absolute path
[fetch]
    prune = true
[grep]
    extendedRegexp = true
[init]
    defaultBranch = main
[push]
    autoSetupRemote = true
[user]
    name = ...
    email = ...
