###    global git config  (~/.gitconfig)

[core]
    autocrlf = input
    eol = lf
    editor = nano
    excludesFile = ~/.gitignore  # default is: '~/.config/git/ignore'
    sshCommand = 'C:\\Windows\\System32\\OpenSSH\\ssh.exe'  # for Windows only
[fetch]
    prune = true
[grep]
    extendedRegexp = true
[init]
    defaultBranch = main
[push]
    autoSetupRemote = true
[user]
    name = ...
    email = ...
